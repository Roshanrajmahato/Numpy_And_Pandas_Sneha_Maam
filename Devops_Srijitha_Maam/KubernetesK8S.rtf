\par }{\rtlch\fcs1 \ab\af1\afs28 \ltrch\fcs0 \b\f1\fs28\kerning0\highlight7\insrsid3440241 \hich\af1\dbch\af31505\loch\f1 6. Sec\hich\af1\dbch\af31505\loch\f1 rets
\par }{\rtlch\fcs1 \af1\afs28 \ltrch\fcs0 \f1\fs28\kerning0\highlight8\insrsid3440241 \tab \hich\af1\dbch\af31505\loch\f1 A Secret in Kubernetes is used to store and manage sensitive information securely, such as:
\par \tab \hich\af1\dbch\af31505\loch\f1 Passwords
\par \tab \hich\af1\dbch\af31505\loch\f1 SSH Keys
\par \tab \hich\af1\dbch\af31505\loch\f1 OAuth tokens
\par \tab \hich\af1\dbch\af31505\loch\f1 TLS certificates
\par \tab \hich\af1\dbch\af31505\loch\f1 API keys}{\rtlch\fcs1 \af1\afs28 \ltrch\fcs0 \f1\fs28\cf1\lang9\langfe16393\kerning0\highlight8\langnp9\insrsid3440241 
\par }{\rtlch\fcs1 \af1\afs28 \ltrch\fcs0 \f1\fs28\cf1\kerning0\insrsid3440241 \hich\af1\dbch\af31505\loch\f1 Unlike ConfigMaps, which handle non-sensitive config data, Secrets are specifically designed for sensitive data and are:
\par \tab \hich\af1\dbch\af31505\loch\f1 Base64 encoded
\par \tab \hich\af1\dbch\af31505\loch\f1 Can be }{\rtlch\fcs1 \ab\af1\afs28 \ltrch\fcs0 \b\f1\fs28\cf6\kerning0\insrsid3440241 \hich\af1\dbch\af31505\loch\f1 encrypted at rest }{\rtlch\fcs1 \af1\afs28 \ltrch\fcs0 \f1\fs28\cf1\kerning0\insrsid3440241 
\hich\af1\dbch\af31505\loch\f1 in the Kubernetes cluster (via KMS, \tab etc.)
\par \tab \hich\af1\dbch\af31505\loch\f1 Restricted via RBAC policies
\par \hich\af1\dbch\af31505\loch\f1 Encryption at Rest: means
\par \tab \hich\af1\dbch\af31505\loch\f1 When you create a Secret, Kubernetes stores it in etcd, which is the backend key-value s\hich\af1\dbch\af31505\loch\f1 tore for cluster data.
\par \hich\af1\dbch\af31505\loch\f1 By default, these secrets are stored in plain base64 in etcd, which isn't secure if someone accesses etcd directly.
\par \hich\af1\dbch\af31505\loch\f1 Encryption at Rest means encrypting data when it is stored (on disk, in databases, etc.), to protect it from unauthorized access.
\par ----------------------------------------------
\par \hich\af1\dbch\af31505\loch\f1 you can encode data with
\par \hich\af1\dbch\af31505\loch\f1 echo -n 'admin' | base64
\par \hich\af1\dbch\af31505\loch\f1 echo -n 'pass123' | base64
\par --------------------------------------------
\par \hich\af1\dbch\af31505\loch\f1 decode
\par \hich\af1\dbch\af31505\loch\f1 echo 'YWRtaW4=' | base64 --decode
\par ---------------------------------------------
\par \hich\af1\dbch\af31505\loch\f1 Create a secret:
\par \hich\af1\dbch\af31505\loch\f1 Example:
\par \hich\af1\dbch\af31505\loch\f1 ---> nano secrets.yml
\par \hich\af1\dbch\af31505\loch\f1 apiVersion: v1
\par \hich\af1\dbch\af31505\loch\f1 kind: Secret
\par \hich\af1\dbch\af31505\loch\f1 metadata:
\par \hich\af1\dbch\af31505\loch\f1   name: db-secret
\par \hich\af1\dbch\af31505\loch\f1 type: Opaque
\par \hich\af1\dbch\af31505\loch\f1 data:
\par \hich\af1\dbch\af31505\loch\f1   username: YWRtaW4=    # base64 for 'admin'
\par \hich\af1\dbch\af31505\loch\f1   password: cGFzczEyMw== # base64 for 'pass123'
\par ----------------------------------------------
\par \hich\af1\dbch\af31505\loch\f1 ---> kubectl apply -f secret.yml
\par ----------------------------------------------
\par \hich\af1\dbch\af31505\loch\f1 Using Secrets in Pods\tab \tab 
\par \hich\af1\dbch\af31505\loch\f1 ---> nano pod.yml
\par \hich\af1\dbch\af31505\loch\f1 1. As Environment Variables
\par \hich\af1\dbch\af31505\loch\f1 apiVersion: v1
\par \hich\af1\dbch\af31505\loch\f1 kind: Pod
\par \hich\af1\dbch\af31505\loch\f1 metadata:
\par \hich\af1\dbch\af31505\loch\f1   name: secret-pod
\par \hich\af1\dbch\af31505\loch\f1 spec:
\par \hich\af1\dbch\af31505\loch\f1   containers:
\par \hich\af1\dbch\af31505\loch\f1   - name: my\hich\af1\dbch\af31505\loch\f1 app
\par \hich\af1\dbch\af31505\loch\f1     image: busybox
\par \hich\af1\dbch\af31505\loch\f1     command: [ "/bin/sh", "-c", "env; sleep 3600" ]
\par \hich\af1\dbch\af31505\loch\f1     env:
\par \hich\af1\dbch\af31505\loch\f1     - name: DB_USER
\par \hich\af1\dbch\af31505\loch\f1       valueFrom:
\par \hich\af1\dbch\af31505\loch\f1         secretKeyRef:
\par \hich\af1\dbch\af31505\loch\f1           name: db-secret
\par \hich\af1\dbch\af31505\loch\f1           key: username
\par \hich\af1\dbch\af31505\loch\f1     - name: DB_PASS
\par \hich\af1\dbch\af31505\loch\f1       valueFrom:
\par \hich\af1\dbch\af31505\loch\f1         secretKeyRef:
\par \hich\af1\dbch\af31505\loch\f1           name: db-secret
\par \hich\af1\dbch\af31505\loch\f1           key: password
\par -----------------------------------
\par \hich\af1\dbch\af31505\loch\f1 ---> kubectl create -f pod.yml
\par \hich\af1\dbch\af31505\loch\f1 ---> kubectl exec -it secret-pod -- env
\par -------------------------------------
\par \hich\af1\dbch\af31505\loch\f1 As Mounted Volume
\par \hich\af1\dbch\af31505\loch\f1 ---> nano pod1.yml
\par \hich\af1\dbch\af31505\loch\f1 apiVersion: v1
\par \hich\af1\dbch\af31505\loch\f1 kind: Pod
\par \hich\af1\dbch\af31505\loch\f1 met\hich\af1\dbch\af31505\loch\f1 adata:
\par \hich\af1\dbch\af31505\loch\f1   name: secret-pod
\par \hich\af1\dbch\af31505\loch\f1 spec:
\par \hich\af1\dbch\af31505\loch\f1   containers:
\par \hich\af1\dbch\af31505\loch\f1   - name: myapp
\par \hich\af1\dbch\af31505\loch\f1     image: busybox
\par \hich\af1\dbch\af31505\loch\f1     command: [ "/bin/sh", "-c", "cat /etc/secret-volume/username; sleep 3600" ]
\par \hich\af1\dbch\af31505\loch\f1     volumeMounts:
\par \hich\af1\dbch\af31505\loch\f1     - name: secret-volume
\par \hich\af1\dbch\af31505\loch\f1       mountPath: /etc/secret-volume
\par \hich\af1\dbch\af31505\loch\f1   volumes:
\par \hich\af1\dbch\af31505\loch\f1   - name: secret-volume
\par \hich\af1\dbch\af31505\loch\f1     secret:
\par \hich\af1\dbch\af31505\loch\f1       secretName: db-secret
\par ------------------------------------
\par \hich\af1\dbch\af31505\loch\f1 ----> kubectl create -f pod1.yml
\par \hich\af1\dbch\af31505\loch\f1 ----> kubectl exec -it secret-pod -- cat /etc/secret-volume/username
\par \hich\af1\dbch\af31505\loch\f1 ----> kubectl get secrets
\par \hich\af1\dbch\af31505\loch\f1 ----> kubectl describe secret <\hich\af1\dbch\af31505\loch\f1 name>a
\par \hich\af1\dbch\af31505\loch\f1 ----> kubectl delete secret <name>
\par ---------------------------------------
