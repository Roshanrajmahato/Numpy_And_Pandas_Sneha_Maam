\par \hich\af1\dbch\af31505\loch\f1 metadata:
\par \hich\af1\dbch\af31505\loch\f1   name: ebs-pvc
\par \hich\af1\dbch\af31505\loch\f1 spec:
\par \hich\af1\dbch\af31505\loch\f1   accessModes:
\par \hich\af1\dbch\af31505\loch\f1     - ReadWriteOnce
\par \hich\af1\dbch\af31505\loch\f1   resources:
\par \hich\af1\dbch\af31505\loch\f1     requests:
\par \hich\af1\dbch\af31505\loch\f1       storage: 5Gi
\par ----------------------------------------------
